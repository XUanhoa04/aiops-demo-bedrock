# =============================================================================
# AIOps Demo Bedrock — Environment Template
# Copy to .env:  cp .env.example .env
# Never commit .env with real credentials.
# =============================================================================

# --- AWS / Amazon Bedrock (optional — rule-based RCA works without keys) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_TEMPERATURE=0.2
BEDROCK_MAX_TOKENS=2048
BEDROCK_MAX_RETRIES=3
# FORCE_RULE_BASED=true

# --- Pipeline wiring (defaults match docker-compose service DNS) ---
RCA_ENGINE_URL=http://aiops-rca-engine:8003
REMEDIATION_URL=http://aiops-remediation:8004
INCIDENT_MANAGER_URL=http://aiops-incident-manager:8002
ENABLE_REMEDIATION_FANOUT=true
ENABLE_REDIS_POLL=true

# Browser-facing Grafana (Trace / Logs deep-links in Incident Console)
# Must be reachable from YOUR browser — not the Docker hostname `lgtm`.
GRAFANA_PUBLIC_URL=http://localhost:3000
TEMPO_DATASOURCE_UID=tempo
LOKI_DATASOURCE_UID=loki


# --- Observability (LGTM) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=demo,service.namespace=aiops-demo
OTEL_METRIC_EXPORT_INTERVAL=5000
PROMETHEUS_URL=http://lgtm:9090
LOKI_URL=http://lgtm:3100
TEMPO_URL=http://lgtm:3200
EVIDENCE_WINDOW_MINUTES=15

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_ANOMALIES=aiops:anomalies
REDIS_QUEUE_INCIDENTS=aiops:incidents

# --- Anomaly detector ---
DETECTION_INTERVAL=30
ZSCORE_THRESHOLD=2.5
EWMA_ALPHA=0.3
WINDOW_SIZE=30
MIN_SAMPLES=8
IFOREST_CONTAMINATION=0.08
HYBRID_VOTE=any
ERROR_RATE_THRESHOLD=0.15
LATENCY_P95_SECONDS_THRESHOLD=0.8
WATCHED_SERVICES=checkout-service,payment-service
INCIDENT_WEBHOOK_URL=http://aiops-incident-manager:8002/incidents/from-anomaly
ENABLE_REDIS_NOTIFY=true
ENABLE_WEBHOOK_NOTIFY=true
ALERT_COOLDOWN_SEC=60

# --- Incident manager ---
INCIDENT_DB_PATH=/data/incidents.db

# --- Remediation ---
REMEDIATION_DB_PATH=/data/remediation.db
AUTO_EXECUTE_LOW_RISK=true
SIMULATE_ONLY=false
# DOCKER_HOST=unix:///var/run/docker.sock
DEFAULT_EXECUTOR=remediation-bot

# --- Feedback ---
FEEDBACK_DB_PATH=/data/feedback.db
SYNC_INCIDENT_MANAGER=true
FP_RATE_WARN=0.25
MIN_SAMPLES_FOR_TUNING=5

# --- Demo apps ---
CHECKOUT_ERROR_RATE=0.02
PAYMENT_ERROR_RATE=0.01
CHECKOUT_BASE_LATENCY_MS=50
PAYMENT_BASE_LATENCY_MS=80
