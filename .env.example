# =============================================================================
# AIOps Demo Bedrock — Environment Template
# Copy to .env and fill in real values:  cp .env.example .env
# Never commit .env with real credentials.
# =============================================================================

# --- AWS / Amazon Bedrock (used by RCA engine Day-2, optional for Day-1) ---
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=replace_me_secret
AWS_DEFAULT_REGION=us-east-1
# Foundation model for root-cause analysis (Claude on Bedrock is typical for CV demos)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# Optional: Bedrock runtime endpoint override (leave empty for regional default)
# AWS_ENDPOINT_URL=

# --- OpenTelemetry (shared by all instrumented services) ---
# LGTM stack exposes OTLP HTTP on 4318 and gRPC on 4317 inside the compose network.
# HTTP is preferred in demos: simpler proxies, fewer protobuf version issues.
OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=demo,service.namespace=aiops-demo
OTEL_METRIC_EXPORT_INTERVAL=5000

# --- Redis (simple event queue between detector → incident-manager) ---
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_ANOMALIES=aiops:anomalies
REDIS_QUEUE_INCIDENTS=aiops:incidents

# --- Service tuning ---
# How often anomaly-detector scrapes Prometheus and re-evaluates (seconds)
ANOMALY_POLL_INTERVAL_SEC=15
# Error-rate threshold (0.0–1.0) before raising an anomaly
ANOMALY_ERROR_RATE_THRESHOLD=0.15
# Latency p95 threshold in milliseconds
ANOMALY_LATENCY_P95_MS=800
# SQLite path inside incident-manager container (volume-backed in compose)
INCIDENT_DB_PATH=/data/incidents.db

# --- Demo / chaos knobs (read by checkout & payment apps) ---
# Baseline error injection probability (0.0–1.0); chaos scripts raise this
CHECKOUT_ERROR_RATE=0.02
PAYMENT_ERROR_RATE=0.01
# Artificial base latency (ms) to make metrics interesting under load
CHECKOUT_BASE_LATENCY_MS=50
PAYMENT_BASE_LATENCY_MS=80

# --- Grafana (otel-lgtm ships with admin/admin by default; change for real use) ---
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=admin
